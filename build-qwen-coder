#!/usr/bin/env bash
set -euo pipefail

# ============================================================================
# Per-model config — the ONLY block that should differ between the build-* scripts.
# Keep the assembly logic below in lock-step.
# ============================================================================
MODEL_NAME="qwen-coder"
BASE_MODEL="batiai/qwen3.5-9b:q6"   # Q6 imatrix quant of qwen3.5:9b (was qwen3.5:9b
                                    # Q4). Coding variant of the qwen 3-model set
                                    # (qwen-content/qwen-coder/qwen-tutor); thinking-on.
ROLE="coding"           # role overlay file: prompts/roles/$ROLE.md

# Modelfile extras (TEMPLATE/RENDERER/PARSER). Qwen3.5 family needs them; the
# qwen3.5 RENDERER/PARSER are what emit + parse the <think> trace. Thinking is
# ON BY DEFAULT at the model level (a generate call with no `think` param returns
# a populated thinking field) — there is no Modelfile knob to set it; it's a
# runtime flag. This model is the designated thinking-on experimental model.
EXTRAS=(
  'TEMPLATE {{ .Prompt }}'
  'RENDERER qwen3.5'
  'PARSER qwen3.5'
)

# Sampler params — tuned for THINKING (Qwen3's recommended thinking-mode sampling:
# temp 0.6 / top_p 0.95 / top_k 20 / min_p 0; never greedy).
# EMPIRICAL (2026-05-31): two attempted "thinking" tweaks both regressed coding
# pass@1 from 87%, so this is back to the proven config:
#   - presence_penalty 1.5 (kept): 1.0 dropped pass@1 to 67%.
#   - NO num_predict: Ollama's default -1 already generates until EOS / context
#     fills (~13.8k tokens), i.e. max headroom. Capping at 8192 truncated long
#     <think> traces and dropped pass@1 to 73%. Don't add it back.
# Note: thinking-qwen is high-variance (67-87% across single 5-attempt runs);
# treat small param deltas as noise unless confirmed over multiple runs.
# num_ctx 49152: base declares 131072 native (too large to load). 65536 spilled
# ~17% to CPU even with KV-cache q4_0; 49152 sits 100% on-GPU at ~71 tok/s
# (measured 2026-06-03). Don't raise without re-checking run-speed.
PARAMS=(
  'num_ctx 49152'
  'temperature 0.6'
  'top_p 0.95'
  'top_k 20'
  'min_p 0'
  'repeat_last_n 256'
  'presence_penalty 1.5'
)

# ============================================================================
# Shared assembly — keep identical across all build-* scripts.
# ============================================================================
AI_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
OUT_DIR="$AI_ROOT/models/$MODEL_NAME"
SYSTEM_FILE="$OUT_DIR/system.txt"
MODELFILE="$OUT_DIR/Modelfile"
mkdir -p "$OUT_DIR"

{
  echo "=== SYSTEM METADATA ==="
  echo "Model: $MODEL_NAME"
  echo "Base:  $BASE_MODEL"
  echo "Built: $(date -u +'%Y-%m-%dT%H:%M:%SZ')"
  echo

  emit_section() {
    local heading="$1" file="$2"
    [ -f "$file" ] || return 0
    echo "=== $heading ==="
    cat "$file"
    echo
  }
  emit_section "CORE DIRECTIVES"    "$AI_ROOT/prompts/system.md"
  emit_section "VOICE"              "$AI_ROOT/prompts/personality.md"
  emit_section "OUTPUT SHAPE"       "$AI_ROOT/prompts/formatting.md"
  emit_section "ROLE GUIDANCE"      "$AI_ROOT/prompts/roles/$ROLE.md"
  emit_section "OPERATIONAL SAFETY" "$AI_ROOT/prompts/safety.md"
  emit_section "USER PROFILE"       "$AI_ROOT/memory/user.md"
  [ "$ROLE" = "tutor" ] && emit_section "LEARNING PROFILE" "$AI_ROOT/memory/learning-profile.md"

  if [ -d "$AI_ROOT/knowledge" ]; then
    echo "=== REFERENCE KNOWLEDGE ==="
    find "$AI_ROOT/knowledge" -type f -name '*.md' -size -100k -print0 \
      | sort -z \
      | while IFS= read -r -d '' f; do
          rel="${f#"$AI_ROOT/"}"
          echo "--- START FILE: $rel ---"
          cat "$f"
          echo "--- END FILE: $rel ---"
          echo
        done
  fi
} > "$SYSTEM_FILE"

if grep -q '"""' "$SYSTEM_FILE"; then
  echo "ERROR: assembled prompt contains triple-quotes; would break Modelfile parsing." >&2
  exit 1
fi

{
  echo "FROM $BASE_MODEL"
  for line in "${EXTRAS[@]}"; do echo "$line"; done
  echo
  echo 'SYSTEM """'
  cat "$SYSTEM_FILE"
  echo '"""'
  echo
  for p in "${PARAMS[@]}"; do echo "PARAMETER $p"; done
} > "$MODELFILE"

ollama create "$MODEL_NAME" -f "$MODELFILE"

echo
echo "✓ Built $MODEL_NAME from $BASE_MODEL"
echo "  System prompt: $(wc -l < "$SYSTEM_FILE") lines, $(wc -w < "$SYSTEM_FILE") words"
echo "  Modelfile:     $MODELFILE"
