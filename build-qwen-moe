#!/usr/bin/env bash
set -euo pipefail

# ============================================================================
# Per-model config — the ONLY block that should differ between build-* scripts.
# Keep the assembly logic below in lock-step with the gemma/granite builders.
# ============================================================================
MODEL_NAME="qwen-moe"
BASE_MODEL="qwen3.6:35b-a3b-mtp-q4_K_M"   # 35B MoE, 3B active, MTP, ~23 GB

# EXPERIMENTAL — does NOT fit on the 10 GB GPU. This 23 GB MoE spills heavily to
# CPU; it is kept off the production lineup and exists only to test whether MoE +
# multi-token-prediction lands in a usable speed band on this box (the dense
# qwen3.6:27b = the retired `qwen-big` managed only ~3 tok/s; the plain 35B MoE
# ~13 tok/s — see TESTING.md). Run-speed it before trusting anything.

ROLE="coding"           # role overlay file: prompts/roles/$ROLE.md
                        # qwen3.6 emphasizes agentic coding + thinking, so the
                        # coding overlay makes it A/B-comparable to gemma/granite-coder.

# Modelfile extras (TEMPLATE/RENDERER/PARSER). EMPTY on purpose: qwen3.6 ships its
# own thinking template/renderer/parser — inherit it via FROM. Do NOT add
# RENDERER/PARSER directives; overriding them errors `does not support thinking`
# (see the retired build-qwen-big notes in TESTING.md). Thinking is ON by default;
# disable per-run with `ollama run --think false qwen-moe`.
EXTRAS=()

# Qwen3 thinking-mode sampling (temp 0.6 / top_p 0.95 / top_k 20 / min_p 0 /
# presence_penalty 1.5; never greedy). No num_predict cap — thinking traces need
# room to complete. num_ctx 16384 keeps the KV cache small so a few more experts
# stay on-GPU; on a heavy spiller, LOWERING num_ctx (e.g. 8192) raises GPU share
# and gen tok/s — sweep with run-speed.py --opt num_ctx=... before committing.
PARAMS=(
  'num_ctx 16384'
  'temperature 0.6'
  'top_p 0.95'
  'top_k 20'
  'min_p 0'
  'repeat_last_n 256'
  'presence_penalty 1.5'
)

# ============================================================================
# Shared assembly — keep identical across all build-* scripts.
# ============================================================================
AI_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
OUT_DIR="$AI_ROOT/models/$MODEL_NAME"
SYSTEM_FILE="$OUT_DIR/system.txt"
MODELFILE="$OUT_DIR/Modelfile"
mkdir -p "$OUT_DIR"

{
  echo "=== SYSTEM METADATA ==="
  echo "Model: $MODEL_NAME"
  echo "Base:  $BASE_MODEL"
  echo "Built: $(date -u +'%Y-%m-%dT%H:%M:%SZ')"
  echo

  emit_section() {
    local heading="$1" file="$2"
    [ -f "$file" ] || return 0
    echo "=== $heading ==="
    cat "$file"
    echo
  }
  emit_section "CORE DIRECTIVES"    "$AI_ROOT/prompts/system.md"
  emit_section "VOICE"              "$AI_ROOT/prompts/personality.md"
  emit_section "OUTPUT SHAPE"       "$AI_ROOT/prompts/formatting.md"
  emit_section "ROLE GUIDANCE"      "$AI_ROOT/prompts/roles/$ROLE.md"
  emit_section "OPERATIONAL SAFETY" "$AI_ROOT/prompts/safety.md"
  emit_section "USER PROFILE"       "$AI_ROOT/memory/user.md"
  [ "$ROLE" = "tutor" ] && emit_section "LEARNING PROFILE" "$AI_ROOT/memory/learning-profile.md"

  if [ -d "$AI_ROOT/knowledge" ]; then
    echo "=== REFERENCE KNOWLEDGE ==="
    find "$AI_ROOT/knowledge" -type f -name '*.md' -size -100k -print0 \
      | sort -z \
      | while IFS= read -r -d '' f; do
          rel="${f#"$AI_ROOT/"}"
          echo "--- START FILE: $rel ---"
          cat "$f"
          echo "--- END FILE: $rel ---"
          echo
        done
  fi
} > "$SYSTEM_FILE"

if grep -q '"""' "$SYSTEM_FILE"; then
  echo "ERROR: assembled prompt contains triple-quotes; would break Modelfile parsing." >&2
  exit 1
fi

{
  echo "FROM $BASE_MODEL"
  for line in "${EXTRAS[@]}"; do echo "$line"; done
  echo
  echo 'SYSTEM """'
  cat "$SYSTEM_FILE"
  echo '"""'
  echo
  for p in "${PARAMS[@]}"; do echo "PARAMETER $p"; done
} > "$MODELFILE"

ollama create "$MODEL_NAME" -f "$MODELFILE"

echo
echo "✓ Built $MODEL_NAME from $BASE_MODEL"
echo "  System prompt: $(wc -l < "$SYSTEM_FILE") lines, $(wc -w < "$SYSTEM_FILE") words"
echo "  Modelfile:     $MODELFILE"
